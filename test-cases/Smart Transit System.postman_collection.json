              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{passenger_email}}\",\n  \"password\": \"{{passenger_password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/passenger/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "passenger",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Passenger Profile (Me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "pm.test('Should return passenger role and profile', function () {",
                  "    pm.expect(response.role).to.equal('passenger');",
                  "    pm.expect(response.user.email).to.equal(pm.collectionVariables.get('passenger_email'));",
                  "});"
                ],
