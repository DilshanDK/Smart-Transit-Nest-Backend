  "item": [
    {
      "name": "1. Passenger Auth & Setup",
      "item": [
        {
          "name": "Register Passenger",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomSuffix = Math.floor(Math.random() * 100000);",
                  "pm.collectionVariables.set('passenger_email', `passenger_${randomSuffix}@example.com`);",
                  "pm.collectionVariables.set('passenger_password', 'passenger123');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const response = pm.response.json();",
                  "pm.test('Should return user details and tokens', function () {",
                  "    pm.expect(response).to.have.property('accessToken');",
                  "    pm.expect(response).to.have.property('refreshToken');",
                  "    pm.expect(response.user).to.have.property('id');",
                  "});",
                  "pm.collectionVariables.set('passenger_id', response.user.id);",
                  "pm.collectionVariables.set('passenger_accessToken', response.accessToken);",
                  "pm.collectionVariables.set('passenger_refreshToken', response.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{passenger_email}}\",\n  \"fullName\": \"Test Passenger {{passenger_email}}\",\n  \"password\": \"{{passenger_password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/passenger/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "passenger",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login Passenger",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('passenger_accessToken', response.accessToken);",
                  "pm.collectionVariables.set('passenger_refreshToken', response.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
